generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("player") // "player" | "admin"
  position      String    @default("any")    // "goalkeeper" | "defender" | "midfielder" | "forward" | "any"
  skillLevel    Int       @default(3)        // 1-5 (user-set)
  fitnessLevel  Int       @default(3)        // 1-5 (user-set)
  phone         String?
  adminSkillRating    Int     @default(3)    // 1-5 (admin-set, private)
  adminFitnessRating  Int     @default(3)    // 1-5 (admin-set, private)
  adminPositions      String  @default("[]") // JSON array (admin-set, private)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  rsvps         RSVP[]
  teamPlayers   TeamPlayer[]
  surveyVotes   SurveyVote[]
  posts         Post[]
  photos        Photo[]
  mvpVotes      MVPVote[]   @relation("MVPVoter")
  mvpReceived   MVPVote[]   @relation("MVPReceiver")
  duties        Duty[]
  payments      Payment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id          String   @id @default(cuid())
  date        DateTime
  location    String   @default("מגרש הכדורגל")
  maxPlayers  Int      @default(14)
  status      String   @default("open") // "open" | "closed" | "completed"
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rsvps       RSVP[]
  teams       Team[]
  survey      Survey?
  posts       Post[]
  photos      Photo[]
  duties      Duty[]
  payments    Payment[]
}

model RSVP {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  status    String   @default("confirmed") // "confirmed" | "declined" | "waitlist"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model Team {
  id        String   @id @default(cuid())
  gameId    String
  name      String   // "קבוצה אדומה" | "קבוצה כחולה" etc
  color     String   // "red" | "blue" | "green" | "yellow"
  createdAt DateTime @default(now())

  game        Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  players     TeamPlayer[]
  wonSurveys  Survey[]     @relation("WinnerTeam")
}

model TeamPlayer {
  id       String  @id @default(cuid())
  teamId   String
  userId   String
  slotNote String? // "שוער" | "שחקן משלים" | null

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Survey {
  id           String   @id @default(cuid())
  gameId       String   @unique
  winnerTeamId String?
  isDraw       Boolean  @default(false)
  isOpen       Boolean  @default(true)
  createdAt    DateTime @default(now())
  closedAt     DateTime?

  game       Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  winnerTeam Team?       @relation("WinnerTeam", fields: [winnerTeamId], references: [id])
  votes      SurveyVote[]
  mvpVotes   MVPVote[]
}

model SurveyVote {
  id           String  @id @default(cuid())
  surveyId     String
  userId       String
  winnerTeamId String?
  isDraw       Boolean @default(false)
  enjoyment    Int     // 1-5
  createdAt    DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
}

model MVPVote {
  id         String   @id @default(cuid())
  surveyId   String
  voterId    String
  receiverId String
  createdAt  DateTime @default(now())

  survey   Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  voter    User   @relation("MVPVoter", fields: [voterId], references: [id], onDelete: Cascade)
  receiver User   @relation("MVPReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([surveyId, voterId])
}

model Post {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Photo {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Duty {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  type      String   // "laundry" | "field_payment"
  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, type])
}

model Payment {
  id        String    @id @default(cuid())
  gameId    String
  userId    String
  paid      Boolean   @default(false)
  paidAt    DateTime?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
}
